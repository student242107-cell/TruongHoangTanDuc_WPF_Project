<Page x:Class="WpfAppDemo.Views.HOME.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppDemo"
      mc:Ignorable="d" 
      d:MinHeight="450" d:MinWidth="800"
      Title="Home">

    <Grid Background="AntiqueWhite">
        <Viewbox Stretch="Uniform">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="LogOut" FontSize="20" FontFamily="Berlin Sans FB"   FontWeight="Bold" Foreground="Blue"
                            Background="Transparent" BorderBrush="Transparent"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Click="LogOut_Click"/>
                    <Button Content="About me" FontSize="20" FontFamily="Berlin Sans FB"   FontWeight="Bold" 
                            Foreground="Orange"
                            Background="Transparent" BorderBrush="Transparent"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Click="AboutMe_Click"/>
                    <Button Content="Delete account" FontSize="20" FontFamily="Berlin Sans FB"   FontWeight="Bold" 
                            Foreground="Red"
                            Background="Transparent" BorderBrush="Transparent"
                            HorizontalAlignment="Left" VerticalAlignment="Top" Click="DeleteAcount_Click"/>
                </StackPanel>
                <TextBlock Text="WELCOME BACK HOME" FontSize="40" FontFamily="Arial Rounded MT Bold"
                            Foreground="Aqua" Background="Azure"
                            HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <StackPanel Orientation="Horizontal">
                    <Image Source="WpfAppDemo;component\Images\ewwww.jpg" 
                            Width="250" Height="250" />
                    <Button Content="Video" FontSize="50" FontFamily="Berlin Sans FB"   FontWeight="Bold" 
                            Foreground="Green"
                            Background="White" BorderBrush="Black"
                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Button Content="Photo" FontSize="50" FontFamily="Berlin Sans FB"   FontWeight="Bold" 
                            Foreground="Gray"
                            Background="White" BorderBrush="Black"
                            HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </StackPanel>
            </StackPanel>
        </Viewbox>
    </Grid>
</Page>
