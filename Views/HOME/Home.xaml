<Page x:Class="WpfAppDemo.Views.HOME.Home"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfAppDemo"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Home">

    <Grid Background="AntiqueWhite">
        <Label Content="HOME" FontSize="40" FontStyle="Italic" FontFamily="Arial Rounded MT Bold"
                Foreground="Aqua" Background="Azure"
                HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="350,50,0,0"/>
        <StackPanel Orientation="Horizontal">
            <Button Content="LogOut" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold" Foreground="Blue"
                    Background="Transparent" BorderBrush="Transparent"
                    Margin="20,10,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top" Click="LogOut_Click"/>
            <Button Content="About me" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold" 
                    Foreground="Orange"
                    Background="Transparent" BorderBrush="Transparent"
                    Margin="30,10,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top" Click="AboutMe_Click"/>
            <Button Content="Delete account" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold" 
                    Foreground="Red"
                    Background="Transparent" BorderBrush="Transparent"
                    Margin="300,10,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top" Click="DeleteAcount_Click"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal">
            <Image Source="E:\TAN DUC\Pictures\vãi ò\414695095_326984580152421_7803660344917719350_n.jpg" 
                   Width="200" Height="200" 
                   Margin="50,150,0,0"/>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Username" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold"
                           Margin="5,200,0,0"/>
                <TextBlock Text="Firstname" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold"
                           Margin="5,20,0,0"/>
                <TextBlock Text="Lastname" FontSize="20" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold"
                           Margin="5,20,0,0"/>
            </StackPanel>
            <Button Content="Video" FontSize="50" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold" 
                    Foreground="Green"
                    Background="White" BorderBrush="Black"
                    Margin="50,200,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button Content="Photo" FontSize="50" FontFamily="Berlin Sans FB" FontStyle="Italic" FontWeight="Bold" 
                    Foreground="Gray"
                    Background="White" BorderBrush="Black"
                    Margin="50,200,0,0" 
                    HorizontalAlignment="Left" VerticalAlignment="Top"/>     
        </StackPanel>
    </Grid>
</Page>
