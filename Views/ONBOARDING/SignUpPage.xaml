<Page x:Class="WpfAppDemo.Views.OnBoarding.SignUpPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppDemo"
        mc:Ignorable="d"
        Title="Sign Up" MinHeight="450" MinWidth="800">
    <Grid Background="OldLace">
        <Viewbox Stretch="Uniform">
            <StackPanel>
                <TextBlock Text="CREATE NEW ACCOUNT" FontSize ="40"  FontFamily="Berlin Sans FB"
                       Foreground="Aqua" Background="Azure"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--Row 0-->
                    <TextBlock x:Name="TxtBlFirstName"
                    Grid.Row="0" Grid.Column="0" Text="Firstname" 
                    FontSize="40" FontFamily="Berlin Sans FB"  
                    Foreground="DarkGreen"/>
                    <TextBox x:Name="txtFirstName" TextAlignment="Left" FontSize="30"
                    Grid.Row="0" Grid.Column="1" Width="300" HorizontalAlignment="Left"/>

                    <!--Row 1-->
                    <TextBlock x:Name="TxtBlLastName"
                               Grid.Row="1" Grid.Column="0" Text="Last name" 
                               FontSize="40" FontFamily="Berlin Sans FB"  
                               Foreground="DarkGreen"/>
                    <TextBox x:Name="txtLastName" TextAlignment="Left" FontSize="30"
                             Grid.Row="1" Grid.Column="1" Width="300" HorizontalAlignment="Left"/>

                    <!--Row 2-->
                    <TextBlock x:Name="TxtBlNewUserName"
                               Grid.Row="2" Grid.Column="0" Text="Username" 
                               FontSize="40" FontFamily="Berlin Sans FB"  
                               Foreground="DarkGreen"/>
                    <TextBox x:Name="txtNewUserName" TextAlignment="Left" FontSize="30"
                             Grid.Row="2" Grid.Column="1" Width="300" HorizontalAlignment="Left"/>

                    <!--Row 3-->
                    <TextBlock x:Name="TxtBlPassword"
                               Grid.Row="3" Grid.Column="0" Text="Password" 
                               FontSize="40" FontFamily="Berlin Sans FB"  
                               Foreground="DarkGreen"/>
                    <TextBox x:Name="txtPassword" TextAlignment="Left" FontSize="30"
                             Grid.Row="3" Grid.Column="1" Width="300" HorizontalAlignment="Left"/>

                    <!--Row 4-->
                    <TextBlock x:Name="TxtBlConfirmPassword"
                                Grid.Row="4" Grid.Column="0" Text="Confirm Password" 
                                FontSize="40" FontFamily="Berlin Sans FB"  
                                Foreground="DarkGreen"/>
                    <TextBox x:Name="txtConfirmPassword" TextAlignment="Left" FontSize="30"
                             Grid.Row="4" Grid.Column="1" Width="300" HorizontalAlignment="Left"/>

                    <!--Row 5-->
                    <Button x:Name="CreateButton"
                            Grid.Row="5" Grid.Column="0"
                            Content="Create" 
                            Height="30" Width="110"
                            Background="CadetBlue" Foreground ="White"
                            HorizontalAlignment="Center" 
                            Click="Create_Click"/>

                    <Button x:Name="BackButton" 
                            Grid.Row="5" Grid.Column="1"
                            Content="Back" FontFamily="Berlin Sans FB"  FontWeight="Bold" Foreground="Blue"
                            Background="Transparent" BorderBrush="Transparent"
                            Click="Back_Click"/>
                </Grid>
            </StackPanel>
        </Viewbox>
    </Grid>
</Page>
